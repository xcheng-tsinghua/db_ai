# Server Configuration (FastAPI Backend)
HOST=0.0.0.0
PORT=8000
DEBUG=true

# =====================================================================
# ACTIVE QWEN SERVER CONFIGURATION (Defaults to Fallback Option C)
# =====================================================================

# Option C: Transformers direct Qwen2.5-7B-Instruct server
QWEN_BASE_URL=http://127.0.0.1:8001/v1
QWEN_MODEL=qwen7b
QWEN_API_KEY=EMPTY
QWEN_TEMPERATURE=0.2
QWEN_MAX_TOKENS=2048
LLM_REQUEST_TIMEOUT_SECONDS=300

# Default LLM Provider Settings
DEFAULT_LLM_PROVIDER=local_qwen

# Windows Agent Worker Settings
ENABLE_WINDOWS_WORKER=false
WINDOWS_WORKER_BASE_URL=http://127.0.0.1:9100

QWEN_MODEL_PATH=/data/models/Qwen2.5-7B-Instruct
QWEN_SERVED_MODEL_NAME=qwen7b
QWEN_HOST=0.0.0.0
QWEN_PORT=8001
QWEN_DEVICE=cuda
QWEN_DTYPE=auto
QWEN_MAX_NEW_TOKENS=2048
QWEN_TOP_P=0.8
QWEN_REPETITION_PENALTY=1.05

# =====================================================================
# INACTIVE CONFIGURATIONS (Uncomment to toggle back to vLLM)
# =====================================================================
# Option B: vLLM local loading (RTX 4090 vLLM Server)
# QWEN_BASE_URL=http://localhost:8001/v1
# QWEN_MODEL=qwen14b
# QWEN_API_KEY=EMPTY
# QWEN_TEMPERATURE=0.2
# QWEN_MAX_TOKENS=2048
#
# QWEN_MODEL_PATH=data/models/Qwen2.5-14B-Instruct-AWQ
# QWEN_SERVED_MODEL_NAME=qwen14b
# QWEN_HOST=0.0.0.0
# QWEN_PORT=8001
# QWEN_MAX_MODEL_LEN=8192
# QWEN_GPU_MEMORY_UTILIZATION=0.90
# QWEN_MAX_NUM_SEQS=2
# QWEN_DTYPE=auto
