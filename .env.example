# App Settings
APP_NAME="AI Agent Base"
DEBUG=True
PORT=8001
HOST="127.0.0.1"

# Active Provider - minimax, openai_compatible, or local_qwen
ACTIVE_PROVIDER="minimax"

# MiniMax Configuration
# Obtain your key from platform.minimax.io
MINIMAX_API_KEY=""
MINIMAX_BASE_URL="https://api.minimaxi.com/v1"
MINIMAX_DEFAULT_TEXT_MODEL="MiniMax-M2.7-highspeed"
MINIMAX_DEFAULT_IMAGE_MODEL="image-01"
MINIMAX_DEFAULT_VIDEO_MODEL="MiniMax-Hailuo-2.3"
MINIMAX_DEFAULT_SPEECH_MODEL="speech-2.8-hd"
MINIMAX_DEFAULT_MUSIC_MODEL="music-2.6"

# OpenAI-Compatible Configuration
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_DEFAULT_TEXT_MODEL="gpt-4o-mini"

# Local Qwen Configuration
# Defaults to Ollama running local model
LOCAL_QWEN_BASE_URL="http://localhost:11434/v1"
LOCAL_QWEN_DEFAULT_MODEL="qwen2.5:7b"

# Local File Agent Safety Settings
# Default workspace directory for local agent file operations
FILE_WORKSPACE_ROOT="E:/document/DeepLearning/db_ai/workspace"
FILE_SIZE_LIMIT_MB=10.0
