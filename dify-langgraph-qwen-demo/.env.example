# Server Configuration (FastAPI Backend)
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Qwen Server Deployment Configuration (Used by vLLM/Docker startup scripts)
QWEN_MODEL_PATH=Qwen/Qwen2.5-14B-Instruct-AWQ
QWEN_SERVED_MODEL_NAME=qwen14b
QWEN_HOST=0.0.0.0
QWEN_PORT=8001
QWEN_MAX_MODEL_LEN=8192
QWEN_GPU_MEMORY_UTILIZATION=0.90
QWEN_MAX_NUM_SEQS=2
QWEN_DTYPE=auto
QWEN_API_KEY=EMPTY

# Backend Qwen Client Configuration (Used by FastAPI/LangGraph)
QWEN_BASE_URL=http://localhost:8001/v1
QWEN_MODEL=qwen14b
QWEN_API_KEY=EMPTY
QWEN_TEMPERATURE=0.2
QWEN_MAX_TOKENS=2048
QWEN_TIMEOUT_SECONDS=120

