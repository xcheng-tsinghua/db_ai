# Windows Worker Configuration
WINDOWS_WORKER_HOST=127.0.0.1
WINDOWS_WORKER_PORT=9100

# Sandbox Configuration
# IMPORTANT: All file operations are restricted to this directory
WINDOWS_WORKSPACE_DIR=C:\ai_worker_workspace

# Security Flags
ALLOW_SHELL=false
ALLOW_FILE_WRITE=true
ALLOW_SCREENSHOT=true
ALLOW_BROWSER_OPEN=true
